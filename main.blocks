"device_play_note" id="?u}23|GG~jPY_Y1VSuk="><comment pinned="false" h="80" w="160">Toca la nota sin bloquear el procesador</comment><value name="note"><shadow type="device_note" id="bN*_wJ7XM/pdMIwsmt(d"><field name="name">262</field></shadow><block type="lists_index_get" id="nJqnmZl5HeL?SDskTy/H"><value name="LIST"><block type="argument_reporter_array" id="pliFIbNp3wZO,7U07zk1"><field name="VALUE">patron</field></block></value><value name="INDEX"><shadow type="math_number" id="[AY)PounLYt]6obWdCD,"><field name="NUM">0</field></shadow><block type="variables_get" id="Sia@lt#a@.PFwZH(`V)C"><field name="VAR" id="]]?on.8F;UoD=w@`);ns">k</field></block></value></block></value><value name="duration"><shadow type="device_beat" id="xrvymPu-}el`:b6}-/kM"><field name="fraction">BeatFraction.Half</field></shadow></value></block></next></block></next></block></next></block></statement></block></statement></block><block type="function_definition" id="tXfmZ!R(z_i2!w1hu1gM" x="4260" y="-49"><mutation name="reproducirBadEndingSeguro" functionid="DhW_N6|(dFXrtwst@Qe`"></mutation><field name="function_name">reproducirBadEndingSeguro</field><comment pinned="false" h="80" w="160">FUNCIÓN PRINCIPAL SEGURA: Métela donde quieras en tus bloques</comment><statement name="STACK"><block type="typescript_statement" id="WMHAG7r7nk.-UpwtmXf/"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="control.inBackground(function () {" line1="        music.setTempo(90)" line2="        badEndingFinalizado = false" line3="        badEndingTiempoInicio = control.millis()" line4="" line5="        // Patrones de notas locales (no ensucian tus variables globales)" line6="        let pLa = [Note.A, Note.C5, Note.E5, Note.C5, Note.A, Note.C5, Note.E5, Note.C5]" line7="        let pFa = [Note.F, Note.A, Note.C5, Note.A, Note.F, Note.A, Note.C5, Note.A]" line8="        let pSol = [Note.G, Note.B, Note.D5, Note.B, Note.G, Note.B, Note.D5, Note.B]" line9="        let pMi = [Note.E, Note.G, Note.B, Note.G, Note.E, Note.G, Note.B, Note.G]" line10="" line11="        // Lanza el texto de forma segura" line12="        basic.showString(&quot;BAD ENDING &quot;, 60)" line13="" line14="        // Bucle de reproducción controlado por tiempo" line15="        while (!badEndingFinalizado) {" line16="            if (!badEndingFinalizado) badEndingTocarCompas(pLa)" line17="            if (!badEndingFinalizado) badEndingTocarCompas(pFa)" line18="            if (!badEndingFinalizado) badEndingTocarCompas(pSol)" line19="            if (!badEndingFinalizado) badEndingTocarCompas(pMi)" line20="        }" line21="" line22="        // Al terminar los 12 segundos, limpia y restablece los valores estándar" line23="        music.setVolume(255)" line24="        led.setBrightness(255) // Devuelve el brillo al máximo para tus otros bloques" line25="        basic.clearScreen()" line26="    })" numlines="27"></mutation></block></statement></block><block type="function_definition" id="fci-gaQxkR[L.e[~+#@3" x="5111" y="-49"><mutation name="INTRO" functionid="N8RNsaTiw@*4NP0UQOd~"></mutation><field name="function_name">INTRO</field><comment pinned="false" h="80" w="160">==========================================
2. FUNCIÓN INTRO (Tu animación completa)
==========================================</comment><statement name="STACK"><block type="controls_if" id=")w.!Gkwe:(oYMrr[QWX!"><value name="IF0"><shadow type="logic_boolean" id="F/[GUjQD7G~X|0U1~IH5"><field name="BOOL">TRUE</field></shadow><block type="logic_compare" id="zTkmeFsjYPgiGzSLSX(5"><field name="OP">EQ</field><value name="A"><shadow type="math_number" id="bc,Xu2K=oTZ/7nmvKL_0"><field name="NUM">0</field></shadow><block type="variables_get" id="y,uavCD[q6Ov-;$AKPJe"><field name="VAR" id="uIIXKDm{!=1gqa8}knWX">Prueba</field></block></value><value name="B"><shadow type="math_number" id="Ci)P;Y=.mX3:u7w~Dz*N"><field name="NUM">0</field></shadow></value></block></value><statement name="DO0"><block type="typescript_statement" id="?V/^e@gN7at`Ys8F2hm{"><mutation xmlns="http://www.w3.org/1999/xhtml" line0="control.inBackground(function () {" line1="        music.setVolume(255)" line2="        for (let i = 0; i &lt; 2; i++) {" line3="            music.play(music.tonePlayable(233, music.beat(BeatFraction.Half)), music.PlaybackMode.UntilDone)" line4="            music.play(music.tonePlayable(220, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)" line5="            music.play(music.tonePlayable(233, music.beat(BeatFraction.Half)), music.PlaybackMode.UntilDone)" line6="            music.play(music.tonePlayable(311, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)" line7="            music.play(music.tonePlayable(294, music.beat(BeatFraction.Half)), music.PlaybackMode.UntilDone)" line8="            music.play(music.tonePlayable(233, music.beat(BeatFraction.Quarter)), music.PlaybackMode.UntilDone)" line9="            music.play(music.tonePlayable(220, music.beat(BeatFraction.Whole)), music.PlaybackMode.UntilDone)" line10="        }" line11="        music.play(music.tonePlayable(185, music.beat(BeatFraction.Double)), music.PlaybackMode.UntilDone)" line12="    })" numlines="13"></mutation><next><block type="controls_repeat_ext" id="]j,6AxL?